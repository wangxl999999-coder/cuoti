.list-container {
  min-height: 100vh;
  background: #f5f5f5;
}

.filter-section {
  background: #fff;
  padding: 20rpx;
  position: sticky;
  top: 0;
  z-index: 10;
}

.filter-row {
  display: flex;
  overflow-x: auto;
  white-space: nowrap;
  margin-bottom: 20rpx;
  padding-bottom: 10rpx;
}

.filter-item {
  flex-shrink: 0;
  padding: 12rpx 24rpx;
  background: #f5f5f5;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
  margin-right: 16rpx;
}

.filter-item.active {
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  color: #fff;
}

.status-tabs {
  display: flex;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 8rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #666;
  border-radius: 8rpx;
}

.tab-item.active {
  background: #fff;
  color: #4CAF50;
  font-weight: 500;
}

.question-list {
  padding: 20rpx;
}

.question-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.question-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.question-tag {
  display: flex;
  align-items: center;
}

.question-time {
  font-size: 24rpx;
  color: #999;
}

.question-content {
  margin-bottom: 20rpx;
}

.question-image {
  width: 100%;
  height: 300rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
}

.question-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}

.question-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.error-count {
  font-size: 24rpx;
  color: #999;
}

.difficulty {
  display: flex;
}

.star {
  font-size: 28rpx;
  color: #ddd;
  margin-left: 4rpx;
}

.star.active {
  color: #FFD700;
}

.empty-state {
  padding: 100rpx 40rpx;
  text-align: center;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: #999;
}

.add-fab {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(76, 175, 80, 0.4);
  z-index: 100;
}

.fab-icon {
  font-size: 48rpx;
  color: #fff;
  font-weight: 300;
}

.loading-more, .no-more {
  text-align: center;
  padding: 30rpx;
  font-size: 26rpx;
  color: #999;
}
