<view class="detail-container">
  <view class="question-section" wx:if="{{question}}">
    <view class="section-header">
      <text class="section-title">题目信息</text>
      <view class="question-tags">
        <text class="tag tag-primary">{{question.subject_name}}</text>
        <text class="tag {{question.is_mastered ? 'tag-success' : 'tag-warning'}}">{{question.is_mastered ? '已掌握' : '待掌握'}}</text>
      </view>
    </view>

    <view class="question-image" wx:if="{{question.image_url}}">
      <image src="{{question.image_url}}" mode="aspectFit" bindtap="previewImage"></image>
    </view>

    <view class="question-content" wx:if="{{question.question_text}}">
      <view class="content-label">题目内容</view>
      <view class="content-text">{{question.question_text}}</view>
    </view>

    <view class="answer-section">
      <view class="content-label">正确答案</view>
      <view class="content-text answer-text">{{question.answer_text || '暂无答案'}}</view>
    </view>

    <view class="analysis-section" wx:if="{{question.analysis}}">
      <view class="content-label">解析</view>
      <view class="content-text">{{question.analysis}}</view>
    </view>

    <view class="info-section">
      <view class="info-row" wx:if="{{question.knowledge_points}}">
        <text class="info-label">知识点</text>
        <text class="info-value">{{question.knowledge_points}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">难度</text>
        <view class="difficulty-stars">
          <text wx:for="{{3}}" wx:key="index" class="star {{index < question.difficulty ? 'active' : ''}}">★</text>
        </view>
      </view>
      <view class="info-row" wx:if="{{question.source}}">
        <text class="info-label">来源</text>
        <text class="info-value">{{question.source}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">做错次数</text>
        <text class="info-value">{{question.error_count}}次</text>
      </view>
      <view class="info-row">
        <text class="info-label">记录时间</text>
        <text class="info-value">{{question.create_time}}</text>
      </view>
    </view>
  </view>

  <view class="practice-section">
    <view class="section-header">
      <text class="section-title">举一反三</text>
    </view>
    <view class="practice-tip">基于该错题生成同类型练习题，巩固知识点</view>
    
    <view class="related-questions" wx:if="{{relatedQuestions.length > 0}}">
      <view class="related-item" wx:for="{{relatedQuestions}}" wx:key="id" bindtap="goToPractice" data-id="{{item.id}}">
        <view class="related-num">{{index + 1}}</view>
        <view class="related-content">
          <view class="related-text">{{item.question_text}}</view>
          <view class="related-type">
            <text class="tag tag-info">{{item.question_type === 1 ? '单选' : item.question_type === 2 ? '多选' : item.question_type === 3 ? '填空' : '解答'}}</text>
          </view>
        </view>
        <text class="related-arrow">›</text>
      </view>
    </view>
    
    <view class="empty-practice" wx:else>
      <view class="empty-icon">📝</view>
      <view class="empty-text">暂无相关练习题</view>
    </view>
  </view>

  <view class="action-section">
    <view class="action-btn {{question.is_mastered ? '' : 'btn-primary'}}" bindtap="toggleMastered">
      <text>{{question.is_mastered ? '取消掌握' : '标记掌握'}}</text>
    </view>
    <view class="action-btn btn-primary" bindtap="startPractice">
      <text>开始练习</text>
    </view>
  </view>

  <view class="points-popup" wx:if="{{showPointsAnimation}}" animation="{{pointsAnimation}}">
    <view class="points-content">
      <view class="points-emoji">🎉</view>
      <view class="points-big">+10</view>
      <view class="points-desc">掌握奖励</view>
    </view>
  </view>
</view>
