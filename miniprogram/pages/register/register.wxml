<view class="register-container">
  <view class="header-section">
    <view class="step-indicator">
      <view class="step-item {{currentStep >= 1 ? 'active' : ''}}">
        <view class="step-circle">{{currentStep > 1 ? '✓' : '1'}}</view>
        <text class="step-text">填写信息</text>
      </view>
      <view class="step-line {{currentStep >= 2 ? 'active' : ''}}"></view>
      <view class="step-item {{currentStep >= 2 ? 'active' : ''}}">
        <view class="step-circle">{{currentStep > 2 ? '✓' : '2'}}</view>
        <text class="step-text">选择年级</text>
      </view>
      <view class="step-line {{currentStep >= 3 ? 'active' : ''}}"></view>
      <view class="step-item {{currentStep >= 3 ? 'active' : ''}}">
        <view class="step-circle">3</view>
        <text class="step-text">完成</text>
      </view>
    </view>
  </view>

  <view class="form-section">
    <view wx:if="{{currentStep === 1}}" class="step-content">
      <view class="form-item">
        <view class="form-label">手机号</view>
        <input class="form-input" type="number" placeholder="请输入手机号" maxlength="11" value="{{phone}}" bindinput="onPhoneInput" />
      </view>

      <view class="form-item">
        <view class="form-label">昵称</view>
        <input class="form-input" type="text" placeholder="请输入昵称（选填）" maxlength="20" value="{{nickname}}" bindinput="onNicknameInput" />
      </view>

      <view class="form-item">
        <view class="form-label">设置密码</view>
        <input class="form-input" type="password" placeholder="请设置6-20位密码" value="{{password}}" bindinput="onPasswordInput" />
      </view>

      <view class="form-item">
        <view class="form-label">确认密码</view>
        <input class="form-input" type="password" placeholder="请再次输入密码" value="{{confirmPassword}}" bindinput="onConfirmPasswordInput" />
      </view>

      <view class="btn-primary next-btn" bindtap="goToStep2">
        下一步
      </view>
    </view>

    <view wx:if="{{currentStep === 2}}" class="step-content">
      <view class="grade-title">请选择您的年级</view>
      <view class="grade-list">
        <view class="grade-section">
          <view class="section-title">小学</view>
          <view class="grade-row">
            <view wx:for="{{grades}}" wx:if="{{item.id <= 6}}" wx:key="id" class="grade-item {{selectedGrade === item.id ? 'selected' : ''}}" bindtap="selectGrade" data-id="{{item.id}}">
              {{item.name}}
            </view>
          </view>
        </view>

        <view class="grade-section">
          <view class="section-title">初中</view>
          <view class="grade-row">
            <view wx:for="{{grades}}" wx:if="{{item.id >= 7 && item.id <= 9}}" wx:key="id" class="grade-item {{selectedGrade === item.id ? 'selected' : ''}}" bindtap="selectGrade" data-id="{{item.id}}">
              {{item.name}}
            </view>
          </view>
        </view>

        <view class="grade-section">
          <view class="section-title">高中</view>
          <view class="grade-row">
            <view wx:for="{{grades}}" wx:if="{{item.id >= 10}}" wx:key="id" class="grade-item {{selectedGrade === item.id ? 'selected' : ''}}" bindtap="selectGrade" data-id="{{item.id}}">
              {{item.name}}
            </view>
          </view>
        </view>
      </view>

      <view class="btn-group">
        <view class="btn-outline prev-btn" bindtap="goToStep1">
          上一步
        </view>
        <view class="btn-primary next-btn" bindtap="doRegister">
          完成注册
        </view>
      </view>
    </view>

    <view wx:if="{{currentStep === 3}}" class="success-section">
      <view class="success-icon">🎉</view>
      <view class="success-title">注册成功！</view>
      <view class="success-desc">欢迎加入错题本，开启高效学习之旅</view>
      <view class="user-info-card">
        <view class="info-row">
          <text class="info-label">账号</text>
          <text class="info-value">{{phone}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">年级</text>
          <text class="info-value">{{gradeName}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">初始积分</text>
          <text class="info-value text-primary">0 积分</text>
        </view>
      </view>
      <view class="btn-primary start-btn" bindtap="goToHome">
        立即开始使用
      </view>
    </view>
  </view>
</view>
