.detail-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.collection-info {
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  padding: 40rpx 30rpx;
  border-radius: 0 0 40rpx 40rpx;
}

.info-header {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.info-icon {
  font-size: 72rpx;
  margin-right: 20rpx;
}

.info-text {
  flex: 1;
}

.info-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.info-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.info-stats {
  display: flex;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 24rpx 0;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-number {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 4rpx;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.stat-divider {
  width: 1rpx;
  background: rgba(255, 255, 255, 0.2);
}

.action-section {
  display: flex;
  padding: 30rpx;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
}

.filter-section {
  display: flex;
  padding: 0 30rpx;
  margin-bottom: 20rpx;
  gap: 16rpx;
}

.filter-item {
  padding: 12rpx 28rpx;
  background: #fff;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
  border: 2rpx solid transparent;
}

.filter-item.active {
  background: #e8f5e9;
  color: #4CAF50;
  border-color: #4CAF50;
}

.questions-section {
  padding: 0 30rpx;
}

.question-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.question-left {
  margin-right: 20rpx;
}

.question-num {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
}

.question-content {
  flex: 1;
  margin-right: 16rpx;
}

.question-text {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.question-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.meta-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.meta-text {
  font-size: 22rpx;
  color: #999;
}

.question-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.action-icon {
  font-size: 40rpx;
  padding: 8rpx;
}

.empty-state {
  padding: 100rpx 40rpx;
  text-align: center;
  background: #fff;
  border-radius: 20rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: #999;
}

.loading-more, .no-more {
  text-align: center;
  padding: 30rpx;
  font-size: 26rpx;
  color: #999;
}

.add-question-popup {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.popup-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.popup-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.popup-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.popup-close {
  font-size: 36rpx;
  color: #999;
}

.popup-body {
  flex: 1;
  overflow-y: auto;
  padding: 20rpx 30rpx;
}

.search-section {
  margin-bottom: 20rpx;
}

.search-input {
  width: 100%;
  height: 80rpx;
  background: #f8f9fa;
  border-radius: 40rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.select-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.select-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
}

.select-checkbox {
  margin-right: 20rpx;
  margin-top: 8rpx;
}

.select-content {
  flex: 1;
}

.select-text {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.select-meta {
  display: flex;
  gap: 12rpx;
}

.popup-footer {
  display: flex;
  padding: 20rpx 30rpx 40rpx;
  gap: 20rpx;
  flex-shrink: 0;
}

.popup-footer .btn-outline, .popup-footer .btn-primary {
  flex: 1;
}
