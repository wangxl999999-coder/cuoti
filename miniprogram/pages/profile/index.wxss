.profile-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 60rpx;
}

.header-section {
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  padding: 60rpx 30rpx 40rpx;
  border-radius: 0 0 40rpx 40rpx;
}

.user-info {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 48rpx;
  font-weight: bold;
}

.user-text {
  flex: 1;
  margin-left: 24rpx;
}

.nickname {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
}

.user-meta {
  display: flex;
  align-items: center;
}

.meta-item {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.meta-divider {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  margin: 0 16rpx;
}

.points-banner {
  display: flex;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  padding: 30rpx 0;
}

.points-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.points-icon {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.points-info {
  text-align: left;
}

.points-number {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 4rpx;
}

.points-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.points-divider {
  width: 1rpx;
  background: rgba(255, 255, 255, 0.2);
}

.menu-section {
  margin-top: 30rpx;
  padding: 0 30rpx;
}

.menu-group {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.menu-arrow {
  font-size: 36rpx;
  color: #ccc;
}

.logout-section {
  padding: 40rpx 30rpx;
}

.logout-btn {
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  color: #f56c6c;
  border: 2rpx solid #ffebee;
}

.version-info {
  text-align: center;
  padding: 20rpx;
}

.version-text {
  font-size: 24rpx;
  color: #ccc;
}
